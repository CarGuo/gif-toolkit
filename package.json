{
  "name": "gif-toolkit",
  "version": "0.1.1",
  "description": "Gif Toolkit — 网页媒体一站式抓取、转换、优化与上传桌面工具:四档嗅探链路(URL / WebContentsView / 真实 Chrome 反爬 / yt-dlp)+ 离线 .mhtml 导入,视频→GIF/WebP 双层目标自适应压缩,GIF/WebP 修剪/缩放/速度/反向/旋转/裁剪/互转工具箱,内置批处理 + 嗅探/产物历史 + 五种图床上传(自建 Web、GitHub、七牛、阿里云 OSS、腾讯云 COS)。FFmpeg + Gifsicle + Sharp + yt-dlp,跨 macOS / Windows / Linux。",
  "main": "dist/main/index.js",
  "author": {
    "name": "gif-toolkit",
    "email": "gif-toolkit@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n RENDERER,MAIN -c blue,green \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && tsc -p tsconfig.main.json --watch --preserveWatchOutput & wait-on dist/main/index.js && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:info": "node scripts/write-build-info.mjs",
    "prebuild": "node scripts/write-build-info.mjs",
    "start": "cross-env NODE_ENV=production electron .",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "npm rebuild sharp ffmpeg-static ffprobe-static @343dev/gifsicle ytdlp-nodejs",
    "lockfile:lint": "lockfile-lint --path package-lock.json --type npm --validate-https --allowed-hosts npm --validate-integrity --validate-package-names"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.8.0"
  },
  "dependencies": {
    "@343dev/gifsicle": "^1.1.0",
    "axios": "^1.7.7",
    "cheerio": "1.0.0-rc.12",
    "chrome-remote-interface": "0.34.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "p-queue": "^6.6.2",
    "sharp": "^0.33.5",
    "ytdlp-nodejs": "^3.4.4"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/chrome-remote-interface": "0.34.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "2.1.8",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "happy-dom": "15.11.7",
    "lockfile-lint": "4.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "2.1.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.giftoolkit.app",
    "productName": "Gif Toolkit",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "CarGuo",
        "repo": "gif-toolkit",
        "releaseType": "draft"
      }
    ],
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**",
      "node_modules/@343dev/gifsicle/**",
      "node_modules/@img/**",
      "node_modules/sharp/**",
      "node_modules/@ffprobe-installer/**",
      "node_modules/ytdlp-nodejs/bin/**"
    ],
    "mac": {
      "icon": "build/icon.png",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Graphics",
      "maintainer": "gif-toolkit <gif-toolkit@users.noreply.github.com>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
