# gif-toolkit npm supply-chain hygiene (R-15)
#
# 这个文件强制 npm 客户端启用一组反供应链攻击的硬规则。任何修改都属于安全敏感
# 改动,必须在 PR 描述里说明动机并通过 review。
#
# 关联规则: harness/rules/R-15-npm-supply-chain-hygiene.md

# 1) Cooldown / minimum release age
#    新发布的版本必须满 7 天才允许被解析进 lockfile。可以挡住绝大多数
#    "golden hour" 攻击窗口(npm 会在数小时内删掉恶意版本,但一周窗口足以让
#    社区披露)。要给紧急 CVE 补丁开白名单,在命令行加 --no-min-release-age
#    或用 --min-release-age=0 临时关闭(必须在 PR 里说明)。
#
#    单位说明: npm 的 min-release-age 以 *天* 为单位 (npm >= 11.10),与 pnpm
#    的 minimumReleaseAge (分钟) 不同,不要写成 10080。
min-release-age=7

# 2) 禁止 preinstall / install / postinstall 自动执行
#    Shai-Hulud / Nx / axios 等近期主要攻击都依赖 lifecycle hook 在装包阶段
#    跑 payload。本仓所有需要 native rebuild 的依赖都在 npm scripts.postinstall
#    中显式 allowlist(只 rebuild sharp / ffmpeg-static / ffprobe-static /
#    gifsicle / ytdlp-nodejs)。
ignore-scripts=true

# 3) 新增依赖固定到精确版本(1.2.3 而不是 ^1.2.3)
#    保证升级只能通过显式 PR 触发,避免 caret 范围在重新生成 lockfile 时
#    意外拉到新发布的恶意版本。
save-exact=true
save-prefix=

# 4) 强制 engines.node / engines.npm 一致
#    Node 版本不一致会让某些 native rebuild 拉到错误 ABI,放大供应链可疑信号
#    被忽略的概率。
engine-strict=true

# 5) 校验 npm registry 上的 sigstore 签名(npm >= 9.5)
#    仅信任 @latest 标签且带 npm provenance 的发布,降低 token 泄露场景的风险。
audit-signatures=true

# 6) 关掉 funding 提示,避免每次 install 大段输出淹没真正的安全 warning
fund=false
